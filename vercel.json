{
    "version": 2,
    "buildCommand": "cd next-examee && npm install --legacy-peer-deps && npm run build",
    "outputDirectory": "next-examee/.next",
    "framework": "nextjs",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/next-examee/api/$1"
        }
    ]
}